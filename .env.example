# ── MongoDB Atlas ─────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0testing.advfg.mongodb.net/user-management

# ── MongoDB Docker (Local) ────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=secret123
MONGO_DB_NAME=user-management

# ── Backend ───────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

JWT_SECRET=your_very_long_random_jwt_secret_here
JWT_REFRESH_SECRET=your_different_very_long_random_refresh_secret_here

JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
CLIENT_URL=http://localhost:5173

# ── Frontend ──────────────────────────────────────────────────
VITE_API_URL=http://localhost:5001/api

# ── Mongo Express GUI ─────────────────────────────────────────
ME_USERNAME=admin
ME_PASSWORD=mexpress123

# ================================================
#   Instructions:
#   1. Copy this file to .env and fill real values
#   2. Use strong random strings for JWT secrets
# ================================================