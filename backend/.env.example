# ================================================
#   Backend .env.example
#   Copy this to backend/.env and modify
# ================================================

PORT=5001
NODE_ENV=development

# ── MongoDB Connection ─────────────────────────────────────
# For local development without Docker (Atlas)
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/user-management

# For Docker development (uncomment when using docker-compose)
# MONGO_URI=mongodb://admin:secret123@mongo:27017/user-management?authSource=admin

# ── JWT Settings ───────────────────────────────────────────
# Generate strong secrets using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_strong_random_64_char_string
JWT_REFRESH_SECRET=replace_with_different_strong_random_64_char_string

JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Frontend URL (CORS)
CLIENT_URL=http://localhost:5173