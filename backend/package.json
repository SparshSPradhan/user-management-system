{
  "name": "backend",
  "version": "1.0.0",
  "main": "src/server.js",
 "scripts": {
    "start":          "node src/server.js",
    "dev":            "nodemon src/server.js",
    "seed":           "node src/database/seeds/seed.js",
    "seed:fresh":     "node src/database/seeds/seed.js --fresh",
    "seed:dry":       "node src/database/seeds/seed.js --dry-run",
    "migrate":        "node src/database/migrations/runner.js",
    "migrate:status": "node src/database/migrations/runner.js --status",
    "migrate:down":   "node src/database/migrations/runner.js --rollback"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}